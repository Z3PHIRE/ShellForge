{
  "schemaVersion": "1.0",
  "name": "Eclipse Matrix",
  "slug": "eclipse-matrix",
  "description": "Retro-modern black and green prompt with a restrained terminal glow.",
  "intent": "Readable matrix-inspired shell that keeps status and command scanning sharp without going cheesy.",
  "promptLayout": {
    "type": "Matrix",
    "density": "High",
    "lineMode": "SingleLine",
    "separatorStyle": "Retro",
    "promptSymbol": "::",
    "adminWarningStyle": "Inline"
  },
  "palette": {
    "background": "#060B06",
    "surface": "#0B160B",
    "accent": "#5CFF7D",
    "accentSecondary": "#88D96B",
    "text": "#D9FFD6",
    "muted": "#6C9C66",
    "success": "#6DF08D",
    "warning": "#A8F25D",
    "error": "#E86262",
    "info": "#95FF9B"
  },
  "segments": {
    "gitEnabled": true,
    "adminEnabled": true,
    "statusEnabled": true,
    "runtimeEnabled": true,
    "executionTimeEnabled": false,
    "batteryEnabled": false,
    "timeEnabled": true,
    "hostEnabled": true,
    "userEnabled": false,
    "pathMode": "Short"
  },
  "iconDensity": "Low",
  "psReadLine": {
    "editMode": "Windows",
    "predictionColor": "#6C9C66",
    "continuationPrompt": "#6C9C66",
    "colors": {
      "Command": "#5CFF7D",
      "Comment": "#6C9C66",
      "Keyword": "#88D96B",
      "String": "#D9FFD6",
      "Number": "#A8F25D",
      "Operator": "#D9FFD6",
      "Variable": "#95FF9B",
      "Member": "#88D96B",
      "Parameter": "#5CFF7D",
      "Type": "#A8F25D",
      "Selection": "#0B160B",
      "InlinePrediction": "#6C9C66",
      "Error": "#E86262"
    }
  },
  "terminal": {
    "backgroundHex": "#060B06",
    "opacityPercent": 91,
    "cursorStyle": "Block",
    "fontRecommendation": "CaskaydiaCove Nerd Font"
  },
  "compatibility": {
    "nativePromptSupported": true,
    "ohMyPoshProfileAvailable": true,
    "minimumPowerShell": "5.1",
    "notes": [
      "Retro-inspired but tuned for modern readability.",
      "Works especially well on black backgrounds with restrained glow."
    ]
  },
  "preview": {
    "sampleCommand": "Get-History -Count 10",
    "promptExample": "Eclipse Matrix :: terminal focus"
  }
}
